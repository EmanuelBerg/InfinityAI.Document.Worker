{
  "ConnectionStrings": {
    "DefaultConnection": "Server=mysql;Port=3306;Database=infinityai;User=root;Password=changeme;"
  },

  "RabbitMQServer": "rabbitmq",
  "RabbitMQPort":   "5672",

  "InfinityAI": {
    "Gateway": {
      "BaseUrl": "http://infinityai-gateway:8080",
      "ApiKey":  "internal-worker-key"
    }
  },

  "SignalR__BaseUrl":     "http://infinityai-signalr:8080",
  "SignalR__InternalKey": "",

  "DocumentIngestion": {
    "Mode":                                 "ExternalWorker",
    "Enabled":                              true,
    "QueueName":                            "document-ingestion",
    "EmbeddingBatchSize":                   32,
    "MaxConcurrentEmbeddingRequests":       1,
    "MaxAttempts":                          3,
    "ProcessingLockMinutes":                30,
    "LargeFileThresholdBytes":              10485760,
    "EnableStructuredReadyBeforeEmbeddings": true
  },

  "Qdrant": {
    "IsEnabled":        false,
    "DualWriteEnabled": false,
    "SearchEnabled":    false,
    "BaseUrl":          "http://qdrant:6333",
    "CollectionPrefix": "infinityai",
    "Distance":         "Cosine"
  },

  "ImageGeneration": {
    "Enabled": false
  },

  "Logging": {
    "LogLevel": {
      "Default":     "Information",
      "Microsoft":   "Warning",
      "System":      "Warning"
    }
  }
}
